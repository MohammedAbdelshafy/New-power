{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/root/.claude/cost-guardrails/check-budget.sh",
            "timeout": 10,
            "statusMessage": "Checking cost budget..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/root/.claude/cost-guardrails/session-end.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/root/.claude/cost-guardrails/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}